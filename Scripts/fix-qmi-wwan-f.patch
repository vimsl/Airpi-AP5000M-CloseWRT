--- a/drivers/net/usb/qmi_wwan_f.c
+++ b/drivers/net/usb/qmi_wwan_f.c
@@ -xxx,xx +xxx,xx @@ static int qmimux_rx_fixup(struct sk_buff *skb, ...)
 	int offset = 0;
 
 	/* 分配新SKB时预留足够的headroom，防止PPPoE封装时skb_cow失败 */
-	skbn = netdev_alloc_skb(net, pkt_len);
+	skbn = netdev_alloc_skb(net, pkt_len + LL_MAX_HEADER);
 	if (!skbn)
 		return 0;
 
+	/* 预留LL_MAX_HEADER空间，这是Linux内核主线2021年已修复的补丁 */
+	skb_reserve(skbn, LL_MAX_HEADER);
 	skb_put_data(skbn, skb->data + offset + qmimux_hdr_sz, pkt_len);
 
 	return usbnet_skb_return(dev, skbn);
