From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: CloseWRT <closewrt@example.com>
Date: Tue, 29 Jul 2025 22:21:22 +0800
Subject: [PATCH] mediatek: remove MTK_SRAM and MTK_HWLRO capability flags for MT7981/MT7986

These capability flags are not applicable to MT7981 and MT7986 platforms
and should not be advertised. Extracted from upstream 9999-02 without
the unprotected HNAT code additions.

diff --git a/drivers/net/ethernet/mediatek/mtk_eth_soc.h b/drivers/net/ethernet/mediatek/mtk_eth_soc.h
index 000000000000..000000000000 100644
--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.h
+++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.h
@@ -1451,11 +1451,11 @@
 #define MT7981_CAPS  (MTK_GMAC1_SGMII | MTK_GMAC2_SGMII | MTK_GMAC2_GEPHY | \
 		      MTK_MUX_GMAC12_TO_GEPHY_SGMII | MTK_QDMA | \
-		      MTK_RSTCTRL_PPE1 | MTK_SRAM | MTK_PDMA_INT | MTK_HWLRO)
+		      MTK_RSTCTRL_PPE1 | MTK_PDMA_INT)

 
 #define MT7986_CAPS  (MTK_GMAC1_SGMII | MTK_GMAC2_SGMII | \
 		      MTK_MUX_GMAC12_TO_GEPHY_SGMII | MTK_QDMA | \
-		      MTK_RSTCTRL_PPE1 | MTK_SRAM | MTK_PDMA_INT | MTK_HWLRO)
+		      MTK_RSTCTRL_PPE1 | MTK_PDMA_INT)

