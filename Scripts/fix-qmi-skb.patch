--- a/drivers/net/usb/qmi_wwan.c
+++ b/drivers/net/usb/qmi_wwan.c
@@ -100,6 +100,14 @@ static int qmi_wwan_rx_fixup(struct usbnet *dev, struct sk_buff *skb)
 	if (skb->len < (len + padding))
 		return 0;
 
+	/* 确保skb有足够尾部空间，防止PPPoE封装时溢出 */
+	if (skb_tailroom(skb) < ETH_DATA_LEN) {
+		struct sk_buff *new_skb = skb_copy_expand(skb, skb_headroom(skb),
+														  ETH_DATA_LEN, GFP_ATOMIC);
+		if (new_skb) {
+			dev_kfree_skb_any(skb);
+			skb = new_skb;
+		}
+	}
 
 	return usbnet_skb_return(dev, skb);
 }
