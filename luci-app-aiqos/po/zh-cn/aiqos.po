msgid ""
msgstr "Content-Type: text/plain; charset=UTF-8\n"

msgid "5G AI Signal Optimization"
msgstr "5G AI 信号优化"

msgid "AIQoS - Intelligent 5G CPE network optimization via cake-autorate + ModemManager"
msgstr "AIQoS - 基于 cake-autorate + ModemManager 的智能5G CPE网络优化"

msgid "5G AI Optimization"
msgstr "5G AI优化"

msgid "Status"
msgstr "状态"

msgid "Preset Configuration"
msgstr "预设配置"

msgid "Optimization Preset"
msgstr "优化预设"

msgid "Normal User"
msgstr "普通用户"

msgid "Gamer"
msgstr "游戏玩家"

msgid "Geek User"
msgstr "极客用户"

msgid "Daily browsing, anti-bufferbloat only"
msgstr "日常上网，仅防膨胀"

msgid "Low latency for gaming/VoIP"
msgstr "游戏/通话低延迟优先"

msgid "All features enabled (expert mode)"
msgstr "全功能调优 (专家模式)"

msgid "Select a preset to auto-configure switches below. You can still adjust individually."
msgstr "选择预设后下方开关自动联动，之后仍可单独调整"

msgid "Feature Switches"
msgstr "功能开关"

msgid "① Basic Anti-Bufferbloat"
msgstr "① 基础防膨胀"

msgid "Enable cake-autorate to dynamically adjust CAKE bandwidth, eliminate bufferbloat"
msgstr "启用 cake-autorate 动态调整 CAKE 带宽，消除 bufferbloat"

msgid "② Signal Adaptive"
msgstr "② 信号自适应"

msgid "Dynamically adjust bandwidth coefficient based on 5G SINR quality"
msgstr "根据 5G SINR 信号质量动态调整带宽系数"

msgid "③ WiFi Optimization"
msgstr "③ WiFi优化"

msgid "Enable TriTon auto channel/power optimization"
msgstr "启用 TriTon 自动信道/功率优化"

msgid "④ Aggressive ACK"
msgstr "④ 激进ACK"

msgid "Enable CAKE ack-filter aggressive mode, reduce uplink redundant ACKs"
msgstr "启用 CAKE ack-filter aggressive 模式，减少上行冗余 ACK"

msgid "⑤ Night Lock"
msgstr "⑤ 夜间锁频"

msgid "Auto scan and lock best cell at 3:00 AM (3-5s disconnection risk)"
msgstr "凌晨 3:00 自动扫描并锁定信号最优小区 (有3-5秒断网风险)"

msgid "⑥ eBPF Limit Drop"
msgstr "⑥ eBPF极限丢包"

msgid "Intelligently drop low-value bulk packets at XDP layer (expert)"
msgstr "在 XDP 层智能丢弃低价值大包，保障交互流量 (专家功能)"

msgid "⑦ AI Prediction (Experimental)"
msgstr "⑦ AI预测 (实验性)"

msgid "Enable CNN-based signal trend prediction for pre-adjustment"
msgstr "启用基于 CNN 的信号趋势预测，实现预调节"

msgid "Advanced Settings"
msgstr "高级设置"

msgid "Show Experimental Features"
msgstr "显示实验性功能"

msgid "When enabled, AI Prediction switch becomes visible and advanced parameters unlocked"
msgstr "开启后 AI 预测开关可见，高级参数解锁"

msgid "Signal Poll Interval (seconds)"
msgstr "信号轮询间隔 (秒)"

msgid "Minimum Bandwidth (Mbps)"
msgstr "带宽下限 (Mbps)"

msgid "Lock Target Frequency"
msgstr "锁频目标频点"

msgid "e.g. 5078 (n78). Leave empty for auto-scan."
msgstr "例如: 5078 (n78)，留空则自动扫描最优"

msgid "Unavailable: ModemManager not running"
msgstr "不可用: ModemManager 未运行"

msgid "Unavailable: No WiFi hardware"
msgstr "不可用: 无 WiFi 硬件"

msgid "Unavailable: Kernel eBPF not supported"
msgstr "不可用: 内核不支持 eBPF"

msgid "5G AI Optimization - Status Dashboard"
msgstr "5G AI优化 - 状态仪表盘"

msgid "Signal Quality"
msgstr "信号质量"

msgid "Current Bandwidth"
msgstr "当前带宽"

msgid "Network Latency"
msgstr "网络延迟"

msgid "Uptime"
msgstr "运行时间"

msgid "CAKE dynamic"
msgstr "CAKE 动态"

msgid "Anti-bufferbloat only"
msgstr "仅防膨胀"

msgid "Low latency priority"
msgstr "低延迟优先"

msgid "Full feature tuning"
msgstr "全功能调优"

msgid "Presets auto-link switches below. You can still toggle individual switches after selecting a preset."
msgstr "预设自动联动下方开关，选择后仍可单独调整。"
