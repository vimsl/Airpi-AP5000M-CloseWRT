#!/bin/sh

echo "Content-Type: application/json"
echo "Access-Control-Allow-Origin: *"
echo ""

IFACE="wwan0"

# 1. 速率
RX1=$(cat /sys/class/net/$IFACE/statistics/rx_bytes 2>/dev/null || echo 0)
TX1=$(cat /sys/class/net/$IFACE/statistics/tx_bytes 2>/dev/null || echo 0)
sleep 1
RX2=$(cat /sys/class/net/$IFACE/statistics/rx_bytes 2>/dev/null || echo 0)
TX2=$(cat /sys/class/net/$IFACE/statistics/tx_bytes 2>/dev/null || echo 0)
DL_SPEED=$(awk "BEGIN {printf \"%.2f\", ($RX2 - $RX1) * 8 / 1000000}")
UL_SPEED=$(awk "BEGIN {printf \"%.2f\", ($TX2 - $TX1) * 8 / 1000000}")

# 2. 系统温度
SYS_TEMP=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null)
[ -n "$SYS_TEMP" ] && SYS_TEMP=$(awk "BEGIN {printf \"%.1f\", $SYS_TEMP/1000}") || SYS_TEMP="--"

# 3. 自动发现 config_section
CONFIG_SECTION=""
for section in $(uci show qmodem 2>/dev/null | sed -n 's/qmodem\.\([^.]*\)\..*/\1/p' | sort -u); do
    if uci get qmodem.$section.at_port >/dev/null 2>&1; then
        CONFIG_SECTION="$section"
        break
    fi
done

# 默认值
NET_STATUS="disconnected"; NET_MODE="--"; OPERATOR="--"; MCC="--"; MNC="--"
CELLID="--"; PCI="--"; ARFCN="--"; BAND="--"; ULBW="--"; DLBW="--"; BW="--"
RSRP="--"; RSRQ="--"; SINR="--"; QCI="--"; IMEI="--"
IPV4="--"; IPV6="--"; MODEM_TEMP="$SYS_TEMP"; CONNECT_STATUS="No"

# 4. 通过 ubus 获取 qmodem 数据
get_val() { echo "$1" | jsonfilter -e "@.modem_info[$2].value" 2>/dev/null; }

if [ -n "$CONFIG_SECTION" ]; then
    BASE_RAW=$(ubus call qmodem base_info "{\"config_section\":\"$CONFIG_SECTION\"}" 2>/dev/null)
    if [ -n "$BASE_RAW" ]; then
        MODEM_TEMP=$(get_val "$BASE_RAW" 4)
        CONNECT_STATUS=$(get_val "$BASE_RAW" 6)
    fi

    CELL_RAW=$(ubus call qmodem cell_info "{\"config_section\":\"$CONFIG_SECTION\"}" 2>/dev/null)
    if [ -n "$CELL_RAW" ]; then
        NET_MODE=$(get_val "$CELL_RAW" 0)
        MCC=$(get_val "$CELL_RAW" 1)
        MNC=$(get_val "$CELL_RAW" 2)
        CELLID=$(get_val "$CELL_RAW" 4)
        PCI=$(get_val "$CELL_RAW" 5)
        ARFCN=$(get_val "$CELL_RAW" 6)
        BAND=$(get_val "$CELL_RAW" 7)
        ULBW=$(get_val "$CELL_RAW" 8 | sed 's/[^0-9]//g')
        DLBW=$(get_val "$CELL_RAW" 9 | sed 's/[^0-9]//g')
        RSRP=$(get_val "$CELL_RAW" 10)
        RSRQ=$(get_val "$CELL_RAW" 11)
        SINR=$(get_val "$CELL_RAW" 12)
        BW="$DLBW"
    fi

    SIM_RAW=$(ubus call qmodem sim_info "{\"config_section\":\"$CONFIG_SECTION\"}" 2>/dev/null)
    if [ -n "$SIM_RAW" ]; then
        OPERATOR=$(get_val "$SIM_RAW" 1)
        IMEI=$(get_val "$SIM_RAW" 3)
    fi
fi

# 5. 通过 uqmi 补充 QCI 和签约速率
QMI_DEV=""; SUB_DL="--"; SUB_UL="--"
for dev in /dev/cdc-wdm*; do
    [ -e "$dev" ] && QMI_DEV="$dev" && break
done

if [ -n "$QMI_DEV" ] && command -v uqmi >/dev/null 2>&1; then
    # 获取 serving system 中的 QCI
    QCI_RAW=$(uqmi -d "$QMI_DEV" --get-serving-system 2>/dev/null)
    if [ -n "$QCI_RAW" ]; then
        QCI_VAL=$(echo "$QCI_RAW" | jsonfilter -e '@.qci' 2>/dev/null)
        [ -n "$QCI_VAL" ] && QCI="$QCI_VAL"
    fi
    # 获取签约速率 (max allowed bitrate from QMI)
    PROFILE_RAW=$(uqmi -d "$QMI_DEV" --get-profile-settings 3 1 2>/dev/null)
    if [ -n "$PROFILE_RAW" ]; then
        SUB_DL=$(echo "$PROFILE_RAW" | jsonfilter -e '@.max_allowed_downlink' 2>/dev/null)
        SUB_UL=$(echo "$PROFILE_RAW" | jsonfilter -e '@.max_allowed_uplink' 2>/dev/null)
        [ -z "$SUB_DL" ] && SUB_DL="--"
        [ -z "$SUB_UL" ] && SUB_UL="--"
    fi
fi

# 6. 通过 AT 命令补充 QCI (备用方案)
if [ "$QCI" = "--" ] && [ -n "$CONFIG_SECTION" ]; then
    AT_PORT=$(uci get qmodem.$CONFIG_SECTION.at_port 2>/dev/null)
    OVERRIDE_AT=$(uci get qmodem.$CONFIG_SECTION.override_at_port 2>/dev/null)
    [ -n "$OVERRIDE_AT" ] && AT_PORT="$OVERRIDE_AT"
    if [ -n "$AT_PORT" ] && [ -e "$AT_PORT" ]; then
        # AT+QNWINFO 可能包含 QCI 信息
        AT_RESP=$(echo -e "AT+QNWINFO\r" | timeout 2 cat "$AT_PORT" 2>/dev/null)
        if echo "$AT_RESP" | grep -q "QCI"; then
            QCI_VAL=$(echo "$AT_RESP" | grep -oP 'QCI[=:]\s*\K[0-9]+' 2>/dev/null)
            [ -n "$QCI_VAL" ] && QCI="$QCI_VAL"
        fi
    fi
fi

# 7. 网络状态
if [ -d "/sys/class/net/$IFACE" ]; then
    CARRIER=$(cat /sys/class/net/$IFACE/carrier 2>/dev/null || echo 0)
    [ "$CARRIER" = "1" ] && NET_STATUS="connected"
fi

# 8. IP 地址
IPV4=$(ifconfig "$IFACE" 2>/dev/null | grep -oE 'inet addr:[0-9.]+' | cut -d: -f2)
IPV6=$(ifconfig "$IFACE" 2>/dev/null | grep -oE 'inet6 addr: [^ ]+' | head -1 | cut -d' ' -f3)
[ -z "$IPV4" ] && IPV4="--"
[ -z "$IPV6" ] && IPV6="--"

# 9. 输出 JSON
cat <<EOF
{
  "networkStatus": "$NET_STATUS",
  "networkMode": "${NET_MODE:-"--"}",
  "operator": "${OPERATOR:-"--"}",
  "band": "${BAND:-"--"}",
  "bandwidth": "${BW:-"--"}",
  "downloadBandwidth": "${DLBW:-"--"}",
  "uploadBandwidth": "${ULBW:-"--"}",
  "subscribedDown": "${SUB_DL:-"--"}",
  "subscribedUp": "${SUB_UL:-"--"}",
  "rsrp": "${RSRP:-"--"}",
  "rsrq": "${RSRQ:-"--"}",
  "sinr": "${SINR:-"--"}",
  "arfcn": "${ARFCN:-"--"}",
  "pci": "${PCI:-"--"}",
  "cellId": "${CELLID:-"--"}",
  "qci": "${QCI:-"--"}",
  "imei": "${IMEI:-"--"}",
  "temperature": "${MODEM_TEMP:-"$SYS_TEMP"}",
  "downloadSpeed": "${DL_SPEED:-"0.00"}",
  "uploadSpeed": "${UL_SPEED:-"0.00"}",
  "ipv4": "${IPV4:-"--"}",
  "ipv6": "${IPV6:-"--"}"
}
EOF
